# LocalRoots MCP environment configuration.
# Copy to .env and fill in your own values. The .env file is gitignored.

# Required. Get yours at https://console.cloud.google.com/google/maps-apis
# This MCP uses the new Places API (places.googleapis.com/v1), not the legacy API.
# Enable "Places API (New)" in your Google Cloud project before generating the key.
GOOGLE_PLACES_API_KEY=

# Optional. Maximum Google Places API requests per second.
# Default is 5. Raise it if your billing tier allows; lower it to be polite.
RATE_LIMIT_RPS=5
